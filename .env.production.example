# ===========================================
# PRODUCTION Firebase — must match production CRM (zica-zima-crm)
# ===========================================
# Next.js embeds these at BUILD TIME. Copy to .env on the VPS before
# running npm run build. Local dev should keep .env on zica-zima-testing.
# ===========================================

NEXT_PUBLIC_FIREBASE_API_KEY=your_production_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=zica-zima-crm.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=zica-zima-crm
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=zica-zima-crm.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
